#!/bin/bash
# shellcheck disable=SC1083

set -euo pipefail
set -x
exec 2>&1

mkdir -p {{pkg.svc_path}}
cd {{pkg.svc_path}}

OIFS=$IFS
IFS='.'

pg_version_file={{pkg.svc_data_path}}/PG_VERSION
moment=$(date '+%Y%m%d%H%M%S')
pwfile="{{pkg.svc_config_path}}/pwfile"
packaged_ident={{pkg.ident}}
postgres_ident=$packaged_ident

function create_postgres_cluster() {

  echo Creating PostgreSQL Cluster

  export randfile="{{pkg.svc_var_path}}/.rnd"
  sudo touch $randfile

  if [[ ! -f "$pwfile" ]]; then
    DB_PASSWORD="{{cfg.init.superuser_password}}"
    if [[ -z "${DB_PASSWORD}" ]]; then
      openssl rand -base64 32 >"$pwfile"
    else
      echo "${DB_PASSWORD}" >"$pwfile"
    fi
    chmod 400 "$pwfile"
  fi

  mkdir -p {{pkg.svc_config_path}}/conf.d
  mkdir -p {{pkg.svc_var_path}}/pg_stat_tmp

  chown -R hab:hab {{pkg.svc_var_path}}

  hab pkg exec "$postgres_ident" initdb -- \
    --username {{cfg.datastore.user}} \
    --encoding {{cfg.init.encoding}} \
    --pgdata {{pkg.svc_data_path}} \
    --pwfile {{pkg.svc_config_path}}/pwfile \
    --no-locale
}

function create_builder_database() {
  # JAH: The createdb call used to happen in the init hook of builder-api, what do?
  if hab pkg exec "$postgres_ident" psql -- --no-password -c ";"; then
    echo The builder database already exists
  else
    echo Creating the builder database
    createdb
  fi
}

function postgres_needs_upgraded() {

  echo Checking if PostgreSQL needs to be upgraded

  # There is an argument to be made that this version check logic should
  # account for a 3 part version number instead of just a 2 part but starting
  # with PostgreSQL 10 the versioning scheme PostgreSQL versions are 2 parts.
  # We do have some 3 part 9.x.x PostgreSQL packages that we're possibly
  # migrating from but given that 9.6.24 has been EOL since Nov 11th 2021
  # hopefully no one has a reason to leverage those packages. Even if someone
  # did use the 9.x.x versions I think this will likely work acceptably and it
  #
  # https://www.postgresql.org/support/versioning/
  # https://endoflife.date/postgresql

  read -ra pg_version <<<"$(sudo cat /hab/svc/builder-datastore/data/PG_VERSION)"
  if (( ${pg_version[0]} == 9 )); then
    installed_ident="core/postgresql${pg_version[0]}${pg_version[1]}"
  else
    installed_ident=core/postgresql${pg_version[0]}
  fi

  read -ra installed_version <<<"$(sudo hab pkg exec "$installed_ident" pg_config -- --version | awk '{print $2}')"
  if [[ ! (${installed_version[0]} =~ [[:digit:]]+ && ${installed_version[1]} =~ [[:digit:]]+) ]]; then
    echo "Failed to parse the version of the installed PostgreSQL: We detected ${installed_version[*]}"
    exit 10
  fi

  read -ra packaged_version <<<"$(sudo hab pkg exec {{pkg.ident}} pg_config -- --version | awk '{print $2}')"
  if [[ ! (${packaged_version[0]} =~ [[:digit:]]+ && ${packaged_version[1]} =~ [[:digit:]]+) ]]; then
    echo "Failed to parse the version of the packaged PostgreSQL: We detected ${packaged_version[*]}"
    exit 11
  fi

  let retval=1
  if ((installed_version[0] < packaged_version[0])); then
    echo "PostgreSQL upgrade needed: ${installed_version[*]} < ${packaged_version[*]}"
    let retval=0
  else
    if ((installed_version[0] == packaged_version[0])); then
      if ((installed_version[1] < packaged_version[1])); then
        echo "PostgreSQL upgrade needed: ${installed_version[*]} < ${packaged_version[*]}"
        let retval=0
      fi
    fi
  fi

  return $retval
}

function manage_upgrade_readme() {
  local readme
  readme="$1/README.txt"
  if [[ ! -f "$readme" ]]; then
    cat <<-EOF >"$readme"
			This directory contains subdirectories used when upgrading PostgreSQL from
			one version to another. The subdirectories are named using the date and time
			of the upgrades. When you feel comfortable with the success of the upgrade
			you may delete these files.
		EOF
  fi
}

start_postgres() {
  echo Starting PostgreSQL
  hab pkg exec "$postgres_ident" pg_ctl -- start -D {{pkg.svc_data_path}}
  for ((i = 0; i < 10; i++)); do
    if ! hab pkg exec "$postgres_ident" pg_isready >/dev/null; then
      : Waiting for PostgreSQL to be ready
      sleep 1
    else
      return 0
    fi
  done
}

stop_postgres() {
  echo Stopping PostgreSQL
  hab pkg exec "$postgres_ident" pg_ctl -- stop -D {{pkg.svc_data_path}}
}

function postgres_installed() {
  if [[ -f "$pg_version_file" ]]; then
    echo PostgreSQL is installed
    return 0
  else
    echo PostgreSQL will be installed
    return 1
  fi
}

function install_postgres() {

  echo Installing PostgreSQL

  create_postgres_cluster
  start_postgres
  create_builder_database

  stop_postgres
}

function upgrade_postgres() {

  echo Upgrading PostgreSQL

  local work_dir
  work_dir="{{pkg.svc_var_path}}/tmp/upgrades/$moment"
  mkdir -p "$work_dir"

  manage_upgrade_readme "$work_dir"

  postgres_ident=$installed_ident

  # pg_ctl start [-D datadir] [-l filename] [-W] [-t seconds] [-s] [-o options] [-p path] [-c]
  start_postgres

  # https://www.postgresql.org/docs/17/upgrading.html

  # STEP 1) Making a backup, making sure that your database is not being updated

  local pg_dump_file
  pg_dump_file="$work_dir/pg_dump.sql"

  # https://www.postgresql.org/docs/17/upgrading.html#UPGRADING-VIA-PGDUMPALL
  # "It is recommended that you use the pg_dump and pg_dumpall programs from the
  # newer version of PostgreSQL, to take advantage of enhancements that might
  # have been made in these programs. Current releases of the dump programs can
  # read data from any server version back to 9.2."
  hab pkg exec $packaged_ident pg_dump >"$pg_dump_file"

  # STEP 2) Shut down the old server

  stop_postgres

  # STEP 3) Rename the old installation directory

  local previous_dir
  previous_dir="$work_dir/previous"
  sudo mv "{{pkg.svc_data_path}}" "$previous_dir"

  # STEP 4) Install the new version of PostgreSQL (as outlined in Chapter 17)
  # This is a noop for us as our habitat package stands in

  # Restore the environment of the packaged PostgreSQL we're upgrading to
  postgres_ident=$packaged_ident

  # STEP 5) If needed, create a new database cluster. Remember you must be logged in as the special database user account
  install_postgres

  # STEP 6) Restore your previous pg_hba.conf and any postgresql.conf modifications
  # This is a noop for us as its managed as part of the hab svc

  # STEP 7) Start the database server (again using the special database user account)
  start_postgres

  # STEP 8) Finally, restore your data from backup
  hab pkg exec $postgres_ident psql -- -d postgres -f "$pg_dump_file"

  # JAH: password upgrade would go here but would we even need it?
  # JAH: will this method of upgrade address it?
  # JAH: scram-sha-256 isn't supported until 10.x

  stop_postgres
}

#-------------------------------------------------------------------------------
# BEGIN "main"
#-------------------------------------------------------------------------------

# These env vars are needed by everything that follows
PGHOST="{{cfg.datastore.host}}"
PGPORT="{{cfg.datastore.port}}"
PGUSER="{{cfg.datastore.user}}"
PGPASSWORD="$(cat {{pkg.svc_config_path}}/pwfile)"
PGDATABASE="{{cfg.datastore.database}}"
export PGHOST PGPORT PGUSER PGPASSWORD PGDATABASE

echo Installing builder-datastore

if ! postgres_installed; then
  install_postgres
elif postgres_needs_upgraded; then
  upgrade_postgres
else
  echo PostgreSQL is installed and no upgrade is needed
fi

IFS="$OIFS"
